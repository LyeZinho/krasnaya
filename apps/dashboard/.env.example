# Frontend Environment Variables
# Copy this file to .env.local and adjust values for your environment

# Development Environment
# In develop mode:
# - Password/2FA authentication is bypassed
# - User is auto-logged as admin
# - No Discord OAuth required
# Set to "develop" to enable development mode, remove or set to "production" for production
VITE_ENVIRONMENT=develop

# API Configuration
VITE_API_URL=http://localhost:3000/api

# Discord OAuth (required for production)
# VITE_DISCORD_CLIENT_ID=your_client_id_here
# VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
