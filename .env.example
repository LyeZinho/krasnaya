# Krasnaya Master Environment Template

# --- Development Environment ---
# Set ENVIRONMENT=develop to enable development mode
# In develop mode:
# - Frontend: Password/2FA authentication is bypassed
# - Frontend: User is auto-logged as admin
# - Frontend: No Discord OAuth required
ENVIRONMENT=develop

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://levelbot:levelbot123@localhost:11900/levelbot
DB_USER=levelbot
DB_PASSWORD=levelbot123
DB_NAME=levelbot

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Discord (Required for @krasnaya/bot-discord) ---
# Create an app at https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# --- App Settings ---
ORIGIN=http://localhost:5173
PORT=3000
